      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "office-rent-mysql"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  o.nama AS office,\n  COUNT(b.id) AS bookings,\n  COALESCE(SUM(CASE WHEN b.status IN ('Dikonfirmasi', 'Selesai') THEN b.total_harga ELSE 0 END), 0) AS revenue\nFROM offices o\nLEFT JOIN bookings b ON b.office_id = o.id\nGROUP BY o.id, o.nama\nORDER BY bookings DESC, revenue DESC\nLIMIT 10;",
          "refId": "A"
        }
      ],
      "title": "Top Offices",
      "type": "table"
