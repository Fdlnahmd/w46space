          "rawSql": "SELECT\n  b.created_at AS created,\n  b.nama_pemesan AS customer,\n  o.nama AS office,\n  b.status,\n  b.payment_status,\n  b.total_harga AS total\nFROM bookings b\nJOIN offices o ON o.id = b.office_id\nORDER BY b.created_at DESC\nLIMIT 20;",
