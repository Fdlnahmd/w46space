# Cloudflare Tunnel Token
# Dapatkan token dari Cloudflare Zero Trust Dashboard
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Database
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=office_rent
DB_USERNAME=root
DB_PASSWORD=password

# Host bindings and ports
# Keep 127.0.0.1 for local/VPS safety. Cloudflare Tunnel can still access services by Docker service name.
FRONTEND_BIND_HOST=127.0.0.1
FRONTEND_PORT=80
MOBILE_BIND_HOST=127.0.0.1
MOBILE_PORT=8080
BACKEND_BIND_HOST=127.0.0.1
BACKEND_PORT=8000
MYSQL_BIND_HOST=127.0.0.1
MYSQL_PORT=3306
GRAFANA_BIND_HOST=127.0.0.1
GRAFANA_PORT=3000
MAILHOG_BIND_HOST=127.0.0.1
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025

# Local-only observability ports
PROMETHEUS_BIND_HOST=127.0.0.1
PROMETHEUS_PORT=9090
DOCKER_STATS_EXPORTER_BIND_HOST=127.0.0.1
DOCKER_STATS_EXPORTER_PORT=9104
LOKI_BIND_HOST=127.0.0.1
LOKI_PORT=3100
DOCKER_PROJECT_LABEL=office-rent

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_DEFAULT_THEME=light
GRAFANA_DOMAIN=localhost
GRAFANA_ROOT_URL=http://localhost:3000
GRAFANA_ENFORCE_DOMAIN=false
GRAFANA_COOKIE_SECURE=false
GRAFANA_METRICS_ENABLED=true

# Prometheus
PROMETHEUS_RETENTION_TIME=7d

# AI Chat (Groq - https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Google OAuth 2.0
# Dapatkan Client ID dari: https://console.cloud.google.com/
# APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client IDs
# Application type: Web application
# Authorized JavaScript origins: http://localhost:80 (lokal) dan https://domain-kamu.com (VPS)
#
# VITE_GOOGLE_CLIENT_ID → di-inject saat `docker-compose build frontend` (bukan runtime)
# GOOGLE_CLIENT_ID      → digunakan backend Laravel untuk verifikasi token
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# App URL (digunakan backend Laravel)
APP_URL=https://your-domain.com
